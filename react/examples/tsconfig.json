{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@retroma/react": ["../src/index.ts"],
      "@retroma/react/composites": ["../src/composites/index.ts"],
      "@retroma/react/styles.css": ["../src/styles/retroma.css"]
    }
  },
  "include": ["./App.tsx"]
}
