{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@retroma/react": ["./src/index.ts"],
      "@retroma/react/composites": ["./src/composites/index.ts"],
      "@retroma/react/components/*": ["./src/components/*"],
      "@retroma/react/base-ui/*": ["./src/base-ui/*"],
      "@retroma/react/hooks/*": ["./src/hooks/*"],
      "@retroma/react/lib/*": ["./src/lib/*"],
      "@retroma/react/styles.css": ["./src/styles/retroma.css"],
      "@retroma/react/globals.css": ["./src/styles/globals.css"],
      "@retroma/react/tokens.css": ["./src/styles/tokens.css"],
      "@retroma/react/theme.css": ["./src/styles/theme.css"]
    }
  },
  "include": ["src", "examples"],
  "exclude": ["dist", "dist-gallery", "node_modules"]
}
